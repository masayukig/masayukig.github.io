      <title>冷蔵庫(東芝GR-C43G)購入</title>
      <link>http://localhost:1313/posts/2010/07/%E5%86%B7%E8%94%B5%E5%BA%AB%E6%9D%B1%E8%8A%9Dgr-c43g%E8%B3%BC%E5%85%A5/</link>
      <pubDate>Mon, 19 Jul 2010 22:26:00 +0900</pubDate>
      <guid>http://localhost:1313/posts/2010/07/%E5%86%B7%E8%94%B5%E5%BA%AB%E6%9D%B1%E8%8A%9Dgr-c43g%E8%B3%BC%E5%85%A5/</guid>
      <description>&lt;p&gt;&lt;a href=&#34;http://www.flickr.com/photos/masayun/4804432674/&#34; title=&#34;DSC00342.JPG by masayukig, on Flickr&#34;&gt;&lt;img alt=&#34;DSC00342.JPG&#34; loading=&#34;lazy&#34; src=&#34;http://farm5.static.flickr.com/4123/4804432674_d5d3672f20.jpg&#34;&gt;
