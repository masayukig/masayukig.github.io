    <item>
      <title>Fedoraにuuencode, uudecodeをインストールしたいとき</title>
      <link>http://localhost:1313/posts/2008/11/fedora%E3%81%ABuuencode-uudecode%E3%82%92%E3%82%A4%E3%83%B3%E3%82%B9%E3%83%88%E3%83%BC%E3%83%AB%E3%81%97%E3%81%9F%E3%81%84%E3%81%A8%E3%81%8D/</link>
