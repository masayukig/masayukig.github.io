    <item>
      <title>Gmailアカウントを作ってみた</title>
      <link>http://localhost:1313/posts/2005/06/gmail%E3%82%A2%E3%82%AB%E3%82%A6%E3%83%B3%E3%83%88%E3%82%92%E4%BD%9C%E3%81%A3%E3%81%A6%E3%81%BF%E3%81%9F/</link>
