    <item>
      <title>Google Readerでスターをつけた記事を自動的にブログ投稿する</title>
      <link>http://localhost:1313/posts/2012/03/google-reader%E3%81%A7%E3%82%B9%E3%82%BF%E3%83%BC%E3%82%92%E3%81%A4%E3%81%91%E3%81%9F%E8%A8%98%E4%BA%8B%E3%82%92%E8%87%AA%E5%8B%95%E7%9A%84%E3%81%AB%E3%83%96%E3%83%AD%E3%82%B0%E6%8A%95%E7%A8%BF%E3%81%99%E3%82%8B/</link>
