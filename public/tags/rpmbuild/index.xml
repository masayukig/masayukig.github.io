      <guid>http://localhost:1313/posts/2009/03/%E4%B8%80%E8%88%AC%E3%83%A6%E3%83%BC%E3%82%B6%E6%A8%A9%E9%99%90%E3%81%A7rpmbuild%E3%82%92%E5%AE%9F%E8%A1%8C/</guid>
      <description>&lt;p&gt;$ echo &amp;ldquo;%_topdir $HOME/src/rpms&amp;rdquo; &amp;gt; $HOME/.rpmmacros
$ mkdir -p $HOME/src/rpms/{BUILD,RPMS,SOURCES,SPECS,SRPMS}&lt;/p&gt;
&lt;p&gt;を、実行して、後は、&lt;/p&gt;
&lt;pre&gt;&lt;code&gt;$ rpmbuild --rebuild hogehuga.src.rpm
&lt;/code&gt;&lt;/pre&gt;
&lt;p&gt;を実行すればおk。&lt;/p&gt;</description>
